# garmin-nostra — example configuration
# Copy this to config.toml and fill in your credentials.
# config.toml is git-ignored; this file is safe to commit.
#
# Secrets: any string value can reference an environment variable with
# the "env:" prefix.  Example:
#   mastodon_access_token = "env:MASTODON_TOKEN"
# The variable must be set in docker-compose.yml (environment: section)
# or passed via `docker run -e`.

# ── Mastodon bot ────────────────────────────────────────────────────────────
[bot]
mastodon_api_base_url = "https://mastodon.social"
mastodon_access_token  = "your_bot_access_token"

# KudosMachine — reply with kudos when someone favourites an activity post.
# Enabled by default for all users. Suppress per-user with suppressKudos = true.
#
# Optionally override the message template. Supports {fav_giver} and
# {activity_user} placeholders (both are @handle@instance strings).
# If omitted, a random message from the built-in pool of 100 is used.
# kudosCustom = ":kudos: {fav_giver} {activity_user} — Einfach fantastisch!"

# ── Sync behaviour ──────────────────────────────────────────────────────────
[sync]
# How often the cron job runs (minutes; values > 59 are valid, e.g. 120)
interval_minutes = 60
# How far back to look on the very first run per user
lookback_days = 30
# Skip GPX/FIT download or Mastodon posts for activities older than N days (optional)
# gpx_max_age_days = 7
# fit_max_age_days = 7
# mastodon_max_age_days = 7
# Seconds between consecutive Mastodon posts (rate-limit safety)
# mastodon_post_delay_s = 2.0
# Timeout in seconds for external HTTP calls
# request_timeout_s = 30

# ── Optional shared CalDAV server ───────────────────────────────────────────
# Remove or leave empty to disable CalDAV globally.
# Per-user opt-in via caldav_enabled = true in each [[users]] block.
[caldav]
url           = "https://your-nextcloud.example.com/remote.php/dav"
username      = "nextcloud_user"
password      = "nextcloud_password"
calendar_name = "Fitness"

# ── Storage ─────────────────────────────────────────────────────────────────
[storage]
db_path   = "/data/garmin_nostra.db"
gpx_dir   = "/data/gpx"
fit_dir   = "/data/fit"
map_dir   = "/data/maps"
token_dir = "/data/tokens"
# log_level = "info"           # debug, info, or error
# log_file  = "/data/garmin_nostra.log"

# ── Users ───────────────────────────────────────────────────────────────────
# Add one [[users]] block per account.
#
# source = "garmin" (default) or "wahoo".
# Garmin users need garmin_username + garmin_password.
# Wahoo users need wahoo_client_id + wahoo_client_secret + wahoo_refresh_token.
#   Register a Wahoo developer app at https://developers.wahooligan.com/cloud
#   and run  python3 src/wahoo_auth.py <client_id> <client_secret>  to obtain
#   the refresh token.
#
# Wahoo users can optionally sync their activities to Garmin Connect by
# setting wahoo_sync_to_garmin = true and providing garmin_username +
# garmin_password in the same block.

[[users]]
name             = "alice"
# source         = "garmin"   # default — can be omitted
garmin_username  = "alice@example.com"
garmin_password  = "garmin_password_alice"
mastodon_handle  = "@alice@fosstodon.org"
caldav_enabled   = true
# suppressKudos  = true   # uncomment to opt out of kudos replies
# Suppress Mastodon posts for matching activity types (glob patterns, case-insensitive).
# Wildcards: * matches any sequence of characters, ? matches one character.
# mastodon_suppress_types = ["*pilates*", "*strength*", "yoga"]

[[users]]
name             = "bob"
garmin_username  = "bob@example.com"
garmin_password  = "garmin_password_bob"
mastodon_handle  = "@bob@mastodon.social"
caldav_enabled   = false
# suppressKudos  = true   # uncomment to opt out of kudos replies
# mastodon_suppress_types = ["*pilates*", "*strength*", "yoga"]

# ── source = "wahoo" — fetch from Wahoo only ────────────────────────────────
# Option A — credentials stored directly in this file:
# [[users]]
# name                  = "carol"
# source                = "wahoo"
# wahoo_client_id       = "your_client_id_here"
# wahoo_client_secret   = "your_client_secret_here"
# wahoo_refresh_token   = "your_refresh_token_here"
# mastodon_handle       = "@carol@mastodon.social"
# caldav_enabled        = false
# wahoo_sync_to_garmin  = true       # upload Wahoo FIT files to Garmin Connect
# garmin_username       = "carol@example.com"   # required if wahoo_sync_to_garmin = true
# garmin_password       = "your_garmin_password_here"
#
# Option B — credentials injected via Docker environment variables
#            (use env:VAR_NAME as the value; set the variable in docker-compose.yml):
# [[users]]
# name                  = "carol"
# source                = "wahoo"
# wahoo_client_id       = "env:CAROL_WAHOO_CLIENT_ID"
# wahoo_client_secret   = "env:CAROL_WAHOO_CLIENT_SECRET"
# wahoo_refresh_token   = "env:CAROL_WAHOO_REFRESH_TOKEN"
# mastodon_handle       = "@carol@mastodon.social"
# caldav_enabled        = false
# wahoo_sync_to_garmin  = true
# garmin_username       = "carol@example.com"
# garmin_password       = "env:CAROL_GARMIN_PASSWORD"

# ── source = "both" — fetch from Wahoo AND Garmin, dedup automatically ──────
# Wahoo is processed first. Activities are tagged [Wahoo] or [Garmin] in the
# DB and Mastodon posts. If an activity from Wahoo was auto-synced to Garmin
# (outside garmin-nostra), the Garmin copy is skipped automatically based on
# matching start time (±2 min window). Nothing is posted or stored twice.
# [[users]]
# name                  = "dave"
# source                = "both"
# wahoo_client_id       = "your_client_id_here"
# wahoo_client_secret   = "your_client_secret_here"
# wahoo_refresh_token   = "your_refresh_token_here"
# garmin_username       = "dave@example.com"
# garmin_password       = "your_garmin_password_here"
# mastodon_handle       = "@dave@mastodon.social"
# caldav_enabled        = false
